# Allow any http(s) origin (store, admin, auth). Override with comma-separated URLs if you want to lock it down.
STORE_CORS=#^https?://.+#
ADMIN_CORS=#^https?://.+#
AUTH_CORS=#^https?://.+#
# Session cookies: medusa-config uses secure/sameSite "auto" (direct IP:port OK; behind TLS proxy, forward X-Forwarded-Proto).
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
# Public URL of this Medusa server (admin API + local file upload URLs; files use this + /static).
MEDUSA_BACKEND_URL=http://localhost:9000
DATABASE_URL=
DB_NAME=medusa-v2
